{
  "name": "torii-cli",
  "version": "0.1.0",
  "description": "OpenAPI-driven CLI for the Torii API — built for LLM agents",
  "license": "MIT",
  "bin": {
    "torii-cli": "./bin/torii-cli"
  },
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18.11.0"
  },
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "lint": "biome check",
