    "prepublishOnly": "npm run lint-types && npm run build && npm test"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^10.0.0",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/jest": "^29.0.3",
    "@types/node": "^22.0.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.0.5",
    "typescript": "^4.9.5"
  },
  "keywords": [
    "torii",
    "cli",
    "openapi",
    "saas-management",
    "llm",
    "agent",
    "automation",
    "api-client"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/toriihq/torii-cli.git"
  },
  "bugs": {
    "url": "https://github.com/toriihq/torii-cli/issues"
  },
  "homepage": "https://github.com/toriihq/torii-cli#readme"
